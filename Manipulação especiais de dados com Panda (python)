      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# 1. Limpeza de Idade e Notas Substitu\n",
        "df['idade'] = df['idade'].replace({'vinte e três': 23, '?': np.nan})\n",
        "df['nota'] = df['nota'].replace({'dez': 10.0})\n",
        "\n",
        "# 2. Convertendo para números e preenchendo vazios com 0 ou média\n",
        "# Usamos o tipo 'Int64' (com I maiúsculo) que permite ter números inteiros mesmo com vazios\n",
        "df['idade'] = pd.to_numeric(df['idade'], errors='coerce').fillna(0).astype(int)\n",
        "df['nota'] = pd.to_numeric(df['nota'], errors='coerce').fillna(0)\n",
        "\n",
        "# 3. Tratando as Datas (Preencher o que deu erro com uma data padrão ou texto)\n",
        "df['data_inscricao'] = pd.to_datetime(df['data_inscricao'], errors='coerce')\n",
        "df['data_inscricao'] = df['data_inscricao'].dt.strftime('%d/%m/%Y').fillna('Data Inválida')\n",
        "\n",
        "# 4. Padronizando o 'Ativo' para Sim/Não em vez de True/False\n",
        "mapeamento = {\n",
        "    True: 'Sim', False: 'Não', 'Sim': 'Sim', 'nao': 'Não', 'TRUE': 'Sim'\n",
        "}\n",
        "df['ativo'] = df['ativo'].map(mapeamento).fillna('Não')\n",
        "\n",
        "# Exibir a tabela bonitinha\n",
        "df"
