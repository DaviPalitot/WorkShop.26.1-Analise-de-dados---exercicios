        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Preparando os dados de temperatura da semana\n",
        "temperaturas_da_semana = np.random.uniform(20, 35, 7)\n",
        "dias = ['Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado', 'Domingo']\n",
        "\n",
        "# Organizando tudo em um relatório estruturado\n",
        "relatorio_clima = pd.DataFrame({\n",
        "    'Dia': dias,\n",
        "    'Graus_Celsius': temperaturas_da_semana\n",
        "})\n",
        "\n",
        "# Realizando os cálculos de monitoramento\n",
        "media_semanal = relatorio_clima['Graus_Celsius'].mean()\n",
        "pico_calor = relatorio_clima['Graus_Celsius'].max()\n",
        "ponto_mais_frio = relatorio_clima['Graus_Celsius'].min()\n",
        "\n",
        "print(\"--- Resumo do Monitoramento Semanal ---\")\n",
        "print(relatorio_clima.round(1))  # Arredondado para facilitar a leitura\n",
        "print(f\"\\nA média de temperatura ficou em: {media_semanal:.1f}°C\")\n",
        "print(f\"O momento mais quente registrou: {pico_calor:.1f}°C\")\n",
        "print(f\"O momento mais fresco registrou: {ponto_mais_frio:.1f}°C\")\n",
        "print(\"-\" * 39)\n",
        "\n",
        "# Configurações visuais para os gráficos\n",
        "plt.style.use('seaborn-v0_8-muted') # Estilo mais elegante\n",
        "fig, axes = plt.subplots(3, 1, figsize=(10, 15))\n",
        "\n",
        "# 1. Gráfico de Linha: Tendência\n",
        "axes[0].plot(dias, temperaturas_da_semana, marker='o', linewidth=2, color='#2c3e50')\n",
        "axes[0].set_title('Tendência da Temperatura ao Longo da Semana', fontsize=14)\n",
        "axes[0].grid(axis='y', linestyle='--', alpha=0.7)\n",
        "\n",
        "# 2. Gráfico de Barras: Comparação entre dias\n",
        "cores_barras = ['#3498db' if t < media_semanal else '#e74c3c' for t in temperaturas_da_semana]\n",
        "axes[1].bar(dias, temperaturas_da_semana, color=cores_barras)\n",
        "axes[1].set_title('Comparativo Diário (Vermelho acima da média)', fontsize=14)\n",
        "\n",
        "# 3. Gráfico de Dispersão: Pontos isolados\n",
        "axes[2].scatter(dias, temperaturas_da_semana, s=100, color='#27ae60', edgecolors='black')\n",
        "axes[2].set_title('Distribuição de Registros Térmicos', fontsize=14)\n",
        "axes[2].set_xlabel('Dias da Semana')\n",
        "\n",
        "# Ajuste final de layout\n",
        "for ax in axes:\n",
        "    ax.set_ylabel('Temperatura (°C)')\n",
        "\n",
        "plt.tight_layout()"
      ],
