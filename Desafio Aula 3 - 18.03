    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ==============================\n",
        "# CONFIGURAÇÃO INICIAL\n",
        "# ==============================\n",
        "np.random.seed(42)  # Garante resultados reproduzíveis\n",
        "\n",
        "dias = ['Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado', 'Domingo']\n",
        "temperaturas = np.random.uniform(20, 35, 7)\n",
        "\n",
        "# ==============================\n",
        "# CRIAÇÃO DO DATAFRAME\n",
        "# ==============================\n",
        "df = pd.DataFrame({\n",
        "    'Dia': dias,\n",
        "    'Temperatura (°C)': temperaturas\n",
        "})\n",
        "\n",
        "# ==============================\n",
        "# CÁLCULOS IMPORTANTES\n",
        "# ==============================\n",
        "media = df['Temperatura (°C)'].mean()\n",
        "max_temp = df['Temperatura (°C)'].max()\n",
        "min_temp = df['Temperatura (°C)'].min()\n",
        "\n",
        "dia_max = df.loc[df['Temperatura (°C)'].idxmax(), 'Dia']\n",
        "dia_min = df.loc[df['Temperatura (°C)'].idxmin(), 'Dia']\n",
        "\n",
        "# ==============================\n",
        "# RELATÓRIO NO CONSOLE\n",
        "# ==============================\n",
        "print(\"\\n=== RELATÓRIO SEMANAL DE TEMPERATURA ===\")\n",
        "print(df.round(1))\n",
        "\n",
        "print(f\"\\nMédia semanal: {media:.1f}°C\")\n",
        "print(f\"Dia mais quente: {dia_max} ({max_temp:.1f}°C)\")\n",
        "print(f\"Dia mais frio: {dia_min} ({min_temp:.1f}°C)\")\n",
        "print(\"=\" * 45)\n",
        "\n",
        "# ==============================\n",
        "# SALVAR DADOS\n",
        "# ==============================\n",
        "df.to_csv(\"relatorio_temperatura.csv\", index=False)\n",
        "\n",
        "# ==============================\n",
        "# VISUALIZAÇÃO\n",
        "# ==============================\n",
        "plt.style.use('seaborn-v0_8-muted')\n",
        "fig, axes = plt.subplots(3, 1, figsize=(12, 16))\n",
        "\n",
        "# ------------------------------\n",
        "# 1. GRÁFICO DE LINHA\n",
        "# ------------------------------\n",
        "axes[0].plot(dias, temperaturas, marker='o', linewidth=2, color='#2c3e50')\n",
        "\n",
        "# Linha da média\n",
        "axes[0].axhline(media, color='red', linestyle='--', label=f'Média ({media:.1f}°C)')\n",
        "\n",
        "# Destaque do ponto máximo e mínimo\n",
        "axes[0].scatter(dia_max, max_temp, color='red', s=120, label='Máxima')\n",
        "axes[0].scatter(dia_min, min_temp, color='blue', s=120, label='Mínima')\n",
        "\n",
        "axes[0].set_title('Tendência da Temperatura na Semana', fontsize=14)\n",
        "axes[0].legend()\n",
        "axes[0].grid(True, linestyle='--', alpha=0.6)\n",
        "\n",
        "# ------------------------------\n",
        "# 2. GRÁFICO DE BARRAS\n",
        "# ------------------------------\n",
        "cores = ['#e74c3c' if t > media else '#3498db' for t in temperaturas]\n",
        "\n",
        "bars = axes[1].bar(dias, temperaturas, color=cores)\n",
        "\n",
        "# Linha da média\n",
        "axes[1].axhline(media, color='black', linestyle='--', label='Média')\n",
        "\n",
        "# Valores nas barras\n",
        "for bar in bars:\n",
        "    altura = bar.get_height()\n",
        "    axes[1].text(bar.get_x() + bar.get_width()/2, altura + 0.3,\n",
        "                 f'{altura:.1f}', ha='center')\n",
        "\n",
        "axes[1].set_title('Comparação de Temperaturas por Dia', fontsize=14)\n",
        "axes[1].legend()\n",
        "\n",
        "# ------------------------------\n",
        "# 3. GRÁFICO DE DISPERSÃO\n",
        "# ------------------------------\n",
        "axes[2].scatter(dias, temperaturas, s=120, color='#27ae60', edgecolors='black')\n",
        "\n",
        "# Média\n",
        "axes[2].axhline(media, color='purple', linestyle='--', label='Média')\n",
        "\n",
        "axes[2].set_title('Distribuição das Temperaturas', fontsize=14)\n",
        "axes[2].set_xlabel('Dias da Semana')\n",
        "axes[2].legend()\n",
        "\n",
        "# ------------------------------\n",
        "# AJUSTES GERAIS\n",
        "# ------------------------------\n",
        "for ax in axes:\n",
        "    ax.set_ylabel('Temperatura (°C)')\n",
        "\n",
        "plt.tight_layout()\n",
        "\n",
        "# ==============================\n",
        "# SALVAR IMAGEM\n",
        "# ==============================\n",
        "plt.savefig(\"graficos_temperatura.png\", dpi=300)\n",
        "\n",
        "# EXIBIR\n",
        "plt.show()"
      ],
