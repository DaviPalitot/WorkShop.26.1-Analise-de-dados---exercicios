CREATE SCHEMA logistica_express;
SET search_path TO logistica_express;

-- Criando as tabelas
CREATE TABLE Transportadoras (
    id_transportadora INT PRIMARY KEY,
    nome_empresa VARCHAR(100) NOT NULL,
    veiculo_tipo VARCHAR(50),
    regiao_atendimento VARCHAR(50)
);

CREATE TABLE Entregas (
    id_entrega INT PRIMARY KEY,
    codigo_rastreio VARCHAR(20) NOT NULL,
    peso_kg DECIMAL(10, 2),
    valor_frete DECIMAL(10, 2),
    id_transportadora INT,
    FOREIGN KEY (id_transportadora) REFERENCES Transportadoras(id_transportadora)
);

