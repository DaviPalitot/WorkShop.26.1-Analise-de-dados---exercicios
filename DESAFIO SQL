-- Relatório de Performance por Transportadora (Join, Agregação e Agrupamento)
SELECT 
    t.nome_empresa,
    COUNT(e.id_entrega) AS total_entregas,
    SUM(e.valor_frete) AS faturamento_total,
    AVG(e.peso_kg) AS peso_medio_cargas
FROM Transportadoras t
JOIN Entregas e ON t.id_transportadora = e.id_transportadora
GROUP BY t.nome_empresa
ORDER BY faturamento_total DESC;
